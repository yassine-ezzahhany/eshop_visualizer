# =========================================================================
# E-SHOP DISTRIBUTED DATABASES - ENV ENVIRONMENT VARIABLES
# =========================================================================
# Default connections route to localhost if unset.
# Use these environment variables on Vercel to route traffic to your 
# local Oracle databases through a TCP tunnel (e.g. ngrok / localtunnel).

# --- SCENARIO 1 CONFIGURATION (Ports 1521-1523) ---
DB_S1_GLOBALE_USER=globale_user
DB_S1_GLOBALE_PASSWORD=globale_password
DB_S1_GLOBALE_HOST=localhost:1521/ESHOP_GLOBALE_PDB

DB_S1_SITE1_USER=globale_user
DB_S1_SITE1_PASSWORD=globale_password
DB_S1_SITE1_HOST=localhost:1522/ESHOP_SITE1_PDB

DB_S1_SITE2_USER=globale_user
DB_S1_SITE2_PASSWORD=globale_password
DB_S1_SITE2_HOST=localhost:1523/ESHOP_SITE2_PDB

# --- SCENARIO 2 CONFIGURATION (Ports 1524-1526) ---
DB_S2_GLOBALE_USER=globale_user
DB_S2_GLOBALE_PASSWORD=globale_password
DB_S2_GLOBALE_HOST=localhost:1524/ESHOP_GLOBALE_PDB

DB_S2_SITE1_USER=globale_user
DB_S2_SITE1_PASSWORD=globale_password
DB_S2_SITE1_HOST=localhost:1525/ESHOP_SITE1_PDB

DB_S2_SITE2_USER=globale_user
DB_S2_SITE2_PASSWORD=globale_password
DB_S2_SITE2_HOST=localhost:1526/ESHOP_SITE2_PDB
